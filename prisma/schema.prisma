generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Result {
  WIN
  LOSE
  DRAW
}

enum Provider {
  GOOGLE
  KAKAO
  NAVER
}

enum RoomMode {
  SOLO
  TEAM
}

enum Role {
  HOST
  PLAYER
}

enum Team {
  A
  B
  NONE
}

enum MatchStatus {
  PENDING
  ACTIVE
  COMPLETED
}

model User {
  id             Int       @id @default(autoincrement())
  username       String?   @unique @db.VarChar(20)
  hashedPassword String?   @map("hashed_password") @db.VarChar(60)
  nickname       String    @unique @db.VarChar(20)
  provider       Provider?
  providerId     String?   @map("provider_id") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  profile     UserProfile?
  roomMembers RoomMember[]
  votes       Vote[]

  @@unique([provider, providerId])
  @@map("users")
}

model UserProfile {
  userId              Int       @id @map("user_id")
  profileImage        String?   @map("profile_image")
  introduce           String?
  level               Int       @default(1)
  experience          Int       @default(0)
  coin                Int       @default(0)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  isTutorialCompleted Boolean   @default(false) @map("is_tutorial_completed")
  lastLoginAt         DateTime? @map("last_login_at")
  totalAttendance     Int?      @map("total_attendance")
  isOnline            Boolean   @default(false) @map("is_online")

  user User @relation(fields: [userId], references: [id])

  @@map("user_profiles")
}

model Room {
  id             Int       @id @default(autoincrement())
  name           String
  mode           RoomMode
  maxPlayers     Int       @map("max_players")
  isPrivate      Boolean   @default(false) @map("is_private")
  hashedPassword String?   @map("hashed_password") @db.VarChar(60)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  startedAt      DateTime? @map("started_at")
  endedAt        DateTime? @map("ended_at")
  deletedAt      DateTime? @map("deleted_at")

  roomMembers RoomMember[]
  matches     Match[]

  @@map("rooms")
}

model RoomMember {
  id        Int       @id @default(autoincrement())
  roomId    Int       @map("room_id")
  userId    Int       @map("user_id")
  role      Role      @default(PLAYER)
  team      Team      @default(NONE)
  isReady   Boolean   @default(false) @map("is_ready")
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user                 User          @relation(fields: [userId], references: [id])
  room                 Room          @relation(fields: [roomId], references: [id])
  matchResults         MatchResult[]
  drawings             Drawing[]
  matchesAsTopicWriter Match[]

  @@unique([roomId, userId])
  @@map("room_members")
}

model Match {
  id            Int         @id @default(autoincrement())
  roomId        Int         @map("room_id")
  status        MatchStatus
  topic         String      @db.VarChar(100)
  topicWriterId Int         @map("topic_writer_id")
  startedAt     DateTime    @default(now()) @map("started_at")
  endedAt       DateTime?   @map("ended_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  room         Room          @relation(fields: [roomId], references: [id])
  matchResults MatchResult[]
  drawings     Drawing[]
  votes        Vote[]
  topicWriter  RoomMember    @relation(fields: [topicWriterId], references: [id])

  @@map("matches")
}

model MatchResult {
  id         Int      @id @default(autoincrement())
  roomUserId Int      @map("room_user_id")
  matchId    Int      @map("match_id")
  result     Result
  recordedAt DateTime @default(now()) @map("recorded_at")

  roomUser RoomMember @relation(fields: [roomUserId], references: [id])
  match    Match      @relation(fields: [matchId], references: [id])

  @@unique([roomUserId, matchId])
  @@map("match_results")
}

model Drawing {
  id         Int    @id @default(autoincrement())
  matchId    Int    @map("match_id")
  roomUserId Int    @map("room_user_id")
  imagePath  String @map("image_path") @db.VarChar(255)

  match      Match      @relation(fields: [matchId], references: [id])
  roomMember RoomMember @relation(fields: [roomUserId], references: [id])
  votes      Vote[]

  @@unique([matchId, roomUserId])
  @@map("drawings")
}

model Vote {
  id        Int @id @default(autoincrement())
  matchId   Int @map("match_id")
  drawingId Int @map("drawing_id")
  voterId   Int @map("voter_id")
  rating    Int

  match   Match   @relation(fields: [matchId], references: [id])
  drawing Drawing @relation(fields: [drawingId], references: [id])
  voter   User    @relation(fields: [voterId], references: [id])

  @@unique([matchId, drawingId, voterId])
  @@map("votes")
}
