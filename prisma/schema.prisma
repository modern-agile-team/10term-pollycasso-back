generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Result {
  WIN
  LOSE
  DRAW
}

enum Provider {
  GOOGLE
  KAKAO
}

enum RoomMode {
  SOLO
  TEAM
}

enum Role {
  HOST
  PLAYER
}

enum Team {
  RED
  BLUE
  NONE
}

enum MatchStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum RoomStatus {
  WAITING
  IN_PROGRESS
  FINISHED
}

model User {
  id             Int       @id @default(autoincrement())
  username       String?   @unique @db.VarChar(20)
  hashedPassword String?   @map("hashed_password") @db.VarChar(60)
  nickname       String    @db.VarChar(30)
  tag            String    @db.VarChar(10)
  provider       Provider?
  providerId     String?   @map("provider_id") @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  profile     UserProfile?
  stats       UserStats?
  roomMembers RoomMember[]
  votes       Vote[]

  @@unique([provider, providerId])
  @@unique([nickname, tag])
  @@map("users")
}

model UserProfile {
  userId              Int       @id @map("user_id")
  profileImage        String?   @map("profile_image")
  introduce           String?
  level               Int       @default(1)
  experience          Int       @default(0)
  coin                Int       @default(0)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  isTutorialCompleted Boolean   @default(false) @map("is_tutorial_completed")
  lastLoginAt         DateTime? @map("last_login_at")
  totalAttendance     Int?      @map("total_attendance")
  isOnline            Boolean   @default(false) @map("is_online")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserStats {
  userId             Int      @id @map("user_id")
  totalMatches       Int      @default(0) @map("total_matches")
  totalWins          Int      @default(0) @map("total_wins")
  totalDraws         Int      @default(0) @map("total_draws")
  totalLoses         Int      @default(0) @map("total_loses")
  winRate            Float    @default(0) @map("win_rate")
  totalVotesReceived Int      @default(0) @map("total_votes_received")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([winRate(sort: Desc)])
  @@map("user_stats")
}

model Room {
  id             Int        @id @default(autoincrement())
  name           String
  mode           RoomMode
  maxPlayers     Int        @map("max_players")
  isPrivate      Boolean    @map("is_private")
  hashedPassword String?    @map("hashed_password") @db.VarChar(60)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  startedAt      DateTime?  @map("started_at")
  endedAt        DateTime?  @map("ended_at")
  status         RoomStatus @default(WAITING)

  roomMembers RoomMember[]
  matches     Match[]

  @@map("rooms")
}

model RoomMember {
  id     Int  @id @default(autoincrement())
  roomId Int  @map("room_id")
  userId Int? @map("user_id")

  userNickname String? @map("user_nickname") @db.VarChar(20)
  userLevel    Int?    @map("user_level")
  userTier     String? @map("user_tier") @db.VarChar(20)

  role      Role      @default(PLAYER)
  team      Team      @default(NONE)
  isReady   Boolean   @default(false) @map("is_ready")
  outfit    Json?
  joinedAt  DateTime  @default(now()) @map("joined_at")
  leftAt    DateTime? @map("left_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user                 User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  room                 Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  matchResults         MatchResult[]
  drawings             Drawing[]
  matchesAsTopicWriter Match[]

  @@unique([roomId, userId])
  @@map("room_members")
}

model Match {
  id            Int         @id @default(autoincrement())
  roomId        Int?        @map("room_id")
  status        MatchStatus
  topic         String      @db.VarChar(100)
  topicWriterId Int?        @map("topic_writer_id")
  startedAt     DateTime    @default(now()) @map("started_at")
  endedAt       DateTime?   @map("ended_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  room         Room?         @relation(fields: [roomId], references: [id], onDelete: SetNull)
  topicWriter  RoomMember?   @relation(fields: [topicWriterId], references: [id], onDelete: SetNull)
  matchResults MatchResult[]
  drawings     Drawing[]
  votes        Vote[]

  @@map("matches")
}

model MatchResult {
  id         Int      @id @default(autoincrement())
  roomUserId Int?     @map("room_user_id")
  matchId    Int      @map("match_id")
  result     Result
  recordedAt DateTime @default(now()) @map("recorded_at")

  roomUser RoomMember? @relation(fields: [roomUserId], references: [id], onDelete: SetNull)
  match    Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([roomUserId, matchId])
  @@index([result])
  @@index([recordedAt])
  @@map("match_results")
}

model Drawing {
  id         Int    @id @default(autoincrement())
  matchId    Int    @map("match_id")
  roomUserId Int?   @map("room_user_id")
  imagePath  String @map("image_path") @db.VarChar(255)

  match      Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  roomMember RoomMember? @relation(fields: [roomUserId], references: [id], onDelete: SetNull)
  votes      Vote[]

  @@unique([matchId, roomUserId])
  @@map("drawings")
}

model Vote {
  id        Int       @id @default(autoincrement())
  matchId   Int       @map("match_id")
  drawingId Int       @map("drawing_id")
  voterId   Int?      @map("voter_id")
  rating    Int
  deletedAt DateTime? @map("deleted_at")

  match   Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  drawing Drawing @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  voter   User?   @relation(fields: [voterId], references: [id], onDelete: SetNull)

  @@unique([matchId, drawingId, voterId])
  @@index([rating])
  @@map("votes")
}
